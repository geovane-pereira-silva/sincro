# =========================================================
# SINCRO — Variáveis de ambiente
# Copie este arquivo para `.env` e preencha os valores.
# O `.env` NUNCA deve ser commitado (está no .gitignore).
# =========================================================

# --- Supabase (backend) ---
# URL do projeto Supabase
VITE_SUPABASE_URL=
# Chave pública (anon / publishable). Segura para o front-end.
VITE_SUPABASE_PUBLISHABLE_KEY=
# ID do projeto Supabase
VITE_SUPABASE_PROJECT_ID=

# --- App ---
VITE_APP_URL=https://sincro.app
VITE_APP_NAME=SINCRO

# --- Asaas (pagamentos) ---
# Ambiente: sandbox (testes) ou production
VITE_ASAAS_ENVIRONMENT=sandbox
ASAAS_ENVIRONMENT=sandbox
# Chave da API do Asaas (SERVER-SIDE — nunca expor no cliente)
ASAAS_API_KEY=
# Token de validação do webhook (definido no painel do Asaas)
ASAAS_WEBHOOK_TOKEN=
